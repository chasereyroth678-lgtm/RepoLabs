PORT=3000
SESSION_SECRET=change-this-to-something-random-and-secret
GEMINI_API_KEY=your-gemini-api-key-from-aistudio.google.com

# NeonDB (serverless Postgres) connection string.
# 1. Create a free project at https://neon.tech
# 2. Open your project -> Connection Details
# 3. Copy the "Connection string" (make sure it includes ?sslmode=require)
# Example:
# DATABASE_URL=postgresql://user:password@ep-something.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=
